# =============================================================================
# Copy to .env and fill in real values. All keys match src/config/env.ts
# =============================================================================

NODE_ENV=development
PORT=4000
APP_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# Swagger UI at http://localhost:4000/api/v1/docs — default on except production; set false to disable
# API_DOCS_ENABLED=true

DATABASE_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

SUPABASE_URL="https://xxxx.supabase.co"
SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...."
SUPABASE_SERVICE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...."

# Optional — leave empty to skip Resend emails (password reset, OTP, security alert)
RESEND_API_KEY=
FROM_EMAIL=onboarding@resend.dev
# Optional — omit entirely from .env if you don’t need them (defaults to empty in code).
# SUPPORT_EMAIL — “Need help? Contact …” in password-change email; if unset, FROM_EMAIL is used as fallback in code.
# SUPPORT_EMAIL=support@yourapp.com
# SECURITY_EMAIL_LOCATION_HINT — extra row in that email, e.g. Kuala Lumpur, MY (leave unset to hide the row).
# SECURITY_EMAIL_LOCATION_HINT=Kuala Lumpur, MY

# Upstash Redis (REST) — required; rate limits + OTP + sessions cache (fail-open if Redis errors)
UPSTASH_REDIS_REST_URL="https://xxxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token-here"

# -----------------------------------------------------------------------------
# Rate limits — sliding window per IP. *WINDOW_MS* is milliseconds.
# Code defaults match the sample values below (omit a line = use default).
# -----------------------------------------------------------------------------
# 900000 ms = 15 minutes  |  60000 ms = 1 min  |  3600000 ms = 1 hour
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_AUTH_WINDOW_MS=900000
# ↑ max auth attempts (login/register/oauth on /auth/*) per window — default 10 per 15 min

RATE_LIMIT_LOGIN_HINT_MAX=20
RATE_LIMIT_LOGIN_HINT_WINDOW_MS=900000
# ↑ login-hint / email-exists style endpoint — default 20 per 15 min

RATE_LIMIT_API_MAX=300
RATE_LIMIT_API_WINDOW_MS=900000
# ↑ general /api/v1/* after rate-limit middleware — default 300 per 15 min

# -----------------------------------------------------------------------------
# Redis TTLs — all values below are SECONDS (not ms).
# Code defaults in parentheses — comment out to use default.
# -----------------------------------------------------------------------------
# EMAIL_OTP_PEPPER — optional extra secret for OTP hash; empty = use SUPABASE_SERVICE_KEY
EMAIL_OTP_PEPPER=

EMAIL_OTP_TTL_SEC=900
# ↑ default 900 = 15 minutes (email verification code lifetime in Redis)

PASSWORD_RESET_TTL_SEC=3600
# ↑ default 3600 = 1 hour (reset token in Redis + email copy)

REDIS_REFRESH_FP_TTL_SEC=2592000
# ↑ default 2592000 = 30 days (refresh-token fingerprint keys)

REDIS_SIGNED_URL_CACHE_TTL_SEC=3000
# ↑ default 3000 = 50 minutes (signed document URL cache; keep below Supabase signed URL TTL)

REDIS_ACCESS_BLACKLIST_FALLBACK_TTL_SEC=900
# ↑ default 900 = 15 minutes (access-token blacklist when JWT has no exp claim)

# -----------------------------------------------------------------------------
# `pnpm run db:seed` (prisma/seed.ts) — head lecturer login
# -----------------------------------------------------------------------------
# SEED_HEAD_EMAIL=head.seed@monash.local
# SEED_HEAD_PASSWORD=SeedHeadLecturer123!
