NODE_ENV=development
PORT=4000
APP_URL=http://localhost:4000
# Comma-separated for multiple origins (e.g. http://localhost:3000,http://localhost:5173)
FRONTEND_URL=http://localhost:3000

DATABASE_URL="mysql://root:@localhost:3306/ts_prisma"
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=ts_prisma

JWT_ACCESS_SECRET=your-access-secret-key
JWT_REFRESH_SECRET=your-refresh-secret-key
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

RESEND_API_KEY=your-api-key
FROM_EMAIL=onboarding@resend.dev
# Optional: in dev, Resend test mode only sends to this email; other recipients use URL from logs
# RESEND_TEST_RECIPIENT=your-resend-account@example.com